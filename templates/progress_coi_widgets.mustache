{{!
    @template gradereport_coifish/progress_coi_widgets

    Community of Inquiry (COI) widgets section.

    @package    gradereport_coifish
    @copyright  2026 South African Theological Seminary (ict@sats.ac.za)
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Renders COI framework widgets in their own section, separate from
    gamification widgets. Each widget measures a dimension of the COI
    framework: social presence, cognitive presence, or teaching presence.

    Context variables required for this template:
    * coi.haswidgets (bool) - Whether any COI widgets are enabled and have data.
    * coi.widgets (array) - Array of COI widget objects.
      * iscoicommunity (bool) - Community engagement widget.
      * iscoipeerconnection (bool) - Peer connection widget.
      * iscoilearningdepth (bool) - Course engagement widget.
      * iscoifeedbackloop (bool) - Feedback loop widget.
      * title (string) - Widget title.
      * total (int) - Total activity count.
      * level (object) - Engagement level with label and class.
      * breakdown (array) - Activity breakdown items.
      * hasbreakdown (bool) - Whether breakdown items exist.
      * action (string) - Graduated action message.
      * hasaction (bool) - Whether an action message exists.
      * isrisk (bool) - Whether the widget is in a risk state.
      * isstale (bool) - Whether activity has gone cold (14+ days).
      * daysinactive (int|null) - Days since last activity.

    Example context (json):
    {
        "coi": {
            "haswidgets": true,
            "widgets": [
                {
                    "iscoicommunity": true,
                    "title": "Community engagement",
                    "total": 12,
                    "isrisk": false,
                    "isstale": false,
                    "daysinactive": 3,
                    "level": {
                        "level": 2,
                        "label": "Developing",
                        "class": "developing"
                    },
                    "breakdown": [
                        {"label": "Discussions", "count": 3},
                        {"label": "Replies", "count": 9}
                    ],
                    "hasbreakdown": true,
                    "action": "You're building community. Consider starting a new discussion.",
                    "hasaction": true
                }
            ]
        }
    }
}}
{{#coi.haswidgets}}
    <div class="gradetracker-coi-section mt-4">
        <h5 class="gradetracker-coi-title mb-3">
            <i class="fa fa-users me-1" aria-hidden="true"></i>
            {{#str}}coi, gradereport_coifish{{/str}}
        </h5>
        <div class="gradetracker-coi-widgets d-flex flex-wrap gap-3">

            {{#coi.widgets}}

                {{! Community Engagement (Social Presence) }}
                {{#iscoicommunity}}
                    <div class="gradetracker-widget gradetracker-coi-widget gradetracker-coi-{{level.class}} {{#isrisk}}gradetracker-widget-risk{{/isrisk}}">
                        <div class="gradetracker-widget-header">
                            {{#isrisk}}<i class="fa fa-exclamation-triangle gradetracker-risk-icon me-1" aria-hidden="true"></i>{{/isrisk}}
                            {{title}}
                            {{#isstale}}<span class="badge bg-warning text-dark ms-auto gradetracker-stale-badge"><i class="fa fa-clock-o me-1" aria-hidden="true"></i>{{daysinactive}}d</span>{{/isstale}}
                        </div>
                        <div class="gradetracker-coi-level-badge gradetracker-coi-level-{{level.class}}">
                            {{level.label}}
                        </div>
                        <div class="gradetracker-widget-hero">{{total}}</div>
                        <div class="gradetracker-widget-sub">contributions</div>
                        {{#hasbreakdown}}
                            <div class="gradetracker-coi-breakdown">
                                {{#breakdown}}
                                    <span class="gradetracker-coi-breakdown-item">
                                        <span class="gradetracker-coi-breakdown-count">{{count}}</span> {{label}}
                                    </span>
                                {{/breakdown}}
                            </div>
                        {{/hasbreakdown}}
                        {{#hasaction}}
                            <div class="gradetracker-widget-action {{^isrisk}}gradetracker-widget-guidance{{/isrisk}}">{{action}}</div>
                        {{/hasaction}}
                        <div class="gradetracker-coi-method-link">
                            <a href="#" data-bs-toggle="modal" data-bs-target="#gradetracker-coi-method-modal-community" class="small text-muted">
                                <i class="fa fa-question-circle me-1" aria-hidden="true"></i>{{#str}}coi_how_determined, gradereport_coifish{{/str}}
                            </a>
                        </div>
                    </div>
                {{/iscoicommunity}}

                {{! Peer Connection (Social Presence) }}
                {{#iscoipeerconnection}}
                    <div class="gradetracker-widget gradetracker-coi-widget gradetracker-coi-{{level.class}} {{#isrisk}}gradetracker-widget-risk{{/isrisk}}">
                        <div class="gradetracker-widget-header">
                            {{#isrisk}}<i class="fa fa-exclamation-triangle gradetracker-risk-icon me-1" aria-hidden="true"></i>{{/isrisk}}
                            {{title}}
                            {{#isstale}}<span class="badge bg-warning text-dark ms-auto gradetracker-stale-badge"><i class="fa fa-clock-o me-1" aria-hidden="true"></i>{{daysinactive}}d</span>{{/isstale}}
                        </div>
                        <div class="gradetracker-coi-level-badge gradetracker-coi-level-{{level.class}}">
                            {{level.label}}
                        </div>
                        <div class="gradetracker-widget-hero">{{total}}</div>
                        <div class="gradetracker-widget-sub">interactions</div>
                        {{#hasbreakdown}}
                            <div class="gradetracker-coi-breakdown">
                                {{#breakdown}}
                                    <span class="gradetracker-coi-breakdown-item">
                                        <span class="gradetracker-coi-breakdown-count">{{count}}</span> {{label}}
                                    </span>
                                {{/breakdown}}
                            </div>
                        {{/hasbreakdown}}
                        {{#hasaction}}
                            <div class="gradetracker-widget-action {{^isrisk}}gradetracker-widget-guidance{{/isrisk}}">{{action}}</div>
                        {{/hasaction}}
                        <div class="gradetracker-coi-method-link">
                            <a href="#" data-bs-toggle="modal" data-bs-target="#gradetracker-coi-method-modal-peer" class="small text-muted">
                                <i class="fa fa-question-circle me-1" aria-hidden="true"></i>{{#str}}coi_how_determined, gradereport_coifish{{/str}}
                            </a>
                        </div>
                    </div>
                {{/iscoipeerconnection}}

                {{! Course Engagement (Cognitive Presence) }}
                {{#iscoilearningdepth}}
                    <div class="gradetracker-widget gradetracker-coi-widget gradetracker-coi-{{level.class}} {{#isrisk}}gradetracker-widget-risk{{/isrisk}}">
                        <div class="gradetracker-widget-header">
                            {{#isrisk}}<i class="fa fa-exclamation-triangle gradetracker-risk-icon me-1" aria-hidden="true"></i>{{/isrisk}}
                            {{title}}
                            {{#isstale}}<span class="badge bg-warning text-dark ms-auto gradetracker-stale-badge"><i class="fa fa-clock-o me-1" aria-hidden="true"></i>{{daysinactive}}d</span>{{/isstale}}
                        </div>
                        <div class="gradetracker-coi-level-badge gradetracker-coi-level-{{level.class}}">
                            {{level.label}}
                        </div>
                        <div class="gradetracker-widget-hero">{{total}}</div>
                        <div class="gradetracker-widget-sub">engagements</div>
                        {{#hasbreakdown}}
                            <div class="gradetracker-coi-breakdown">
                                {{#breakdown}}
                                    <span class="gradetracker-coi-breakdown-item">
                                        <span class="gradetracker-coi-breakdown-count">{{count}}</span> {{label}}
                                    </span>
                                {{/breakdown}}
                            </div>
                        {{/hasbreakdown}}
                        {{#hasaction}}
                            <div class="gradetracker-widget-action {{^isrisk}}gradetracker-widget-guidance{{/isrisk}}">{{action}}</div>
                        {{/hasaction}}
                        <div class="gradetracker-coi-method-link">
                            <a href="#" data-bs-toggle="modal" data-bs-target="#gradetracker-coi-method-modal-cognitive" class="small text-muted">
                                <i class="fa fa-question-circle me-1" aria-hidden="true"></i>{{#str}}coi_how_determined, gradereport_coifish{{/str}}
                            </a>
                        </div>
                    </div>
                {{/iscoilearningdepth}}

                {{! Feedback Loop (Teaching Presence) }}
                {{#iscoifeedbackloop}}
                    <div class="gradetracker-widget gradetracker-coi-widget gradetracker-coi-{{level.class}} {{#isrisk}}gradetracker-widget-risk{{/isrisk}}">
                        <div class="gradetracker-widget-header">
                            {{#isrisk}}<i class="fa fa-exclamation-triangle gradetracker-risk-icon me-1" aria-hidden="true"></i>{{/isrisk}}
                            {{title}}
                            {{#isstale}}<span class="badge bg-warning text-dark ms-auto gradetracker-stale-badge"><i class="fa fa-clock-o me-1" aria-hidden="true"></i>{{daysinactive}}d</span>{{/isstale}}
                        </div>
                        <div class="gradetracker-coi-level-badge gradetracker-coi-level-{{level.class}}">
                            {{level.label}}
                        </div>
                        <div class="gradetracker-widget-hero">
                            <span class="gradetracker-completion-ring gradetracker-coi-ring"
                                  data-graded="{{viewed}}"
                                  data-total="{{total}}">
                                <svg viewBox="0 0 36 36" class="gradetracker-ring-svg">
                                    <path class="gradetracker-ring-bg"
                                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                                    <path class="gradetracker-ring-fill"
                                          stroke-dasharray="0, 100"
                                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                                    <text x="18" y="21" class="gradetracker-ring-text">{{percent}}%</text>
                                </svg>
                            </span>
                        </div>
                        <div class="gradetracker-widget-sub">{{viewed}}/{{total}} feedback viewed</div>
                        {{#hasaction}}
                            <div class="gradetracker-widget-action {{^isrisk}}gradetracker-widget-guidance{{/isrisk}}">{{action}}</div>
                        {{/hasaction}}
                        <div class="gradetracker-coi-method-link">
                            <a href="#" data-bs-toggle="modal" data-bs-target="#gradetracker-coi-method-modal-teaching" class="small text-muted">
                                <i class="fa fa-question-circle me-1" aria-hidden="true"></i>{{#str}}coi_how_determined, gradereport_coifish{{/str}}
                            </a>
                        </div>
                    </div>
                {{/iscoifeedbackloop}}

            {{/coi.widgets}}
        </div>
    </div>

    {{! Community Engagement methodology modal }}
    <div class="modal fade" id="gradetracker-coi-method-modal-community" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa fa-info-circle me-1" aria-hidden="true"></i> {{#str}}coi_method_community_title, gradereport_coifish{{/str}}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>{{#str}}coi_method_community_desc, gradereport_coifish{{/str}}</p>
                    <h6 class="fw-bold mt-3">{{#str}}coi_method_signals_title, gradereport_coifish{{/str}}</h6>
                    <p>{{#str}}coi_method_community_signals, gradereport_coifish{{/str}}</p>
                    <h6 class="fw-bold mt-3">{{#str}}coi_method_levels_title, gradereport_coifish{{/str}}</h6>
                    <p>{{#str}}coi_method_levels_desc, gradereport_coifish{{/str}}</p>
                    <div class="alert alert-secondary small py-2 mb-0">
                        <i class="fa fa-book me-1" aria-hidden="true"></i>
                        {{#str}}coi_method_cite, gradereport_coifish{{/str}}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! Peer Connection methodology modal }}
    <div class="modal fade" id="gradetracker-coi-method-modal-peer" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
