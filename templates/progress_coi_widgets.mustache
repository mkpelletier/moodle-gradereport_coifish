                    <p>{{#str}}coi_method_levels_desc, gradereport_coifish{{/str}}</p>
                    <div class="alert alert-secondary small py-2 mb-0">
                        <i class="fa fa-book me-1" aria-hidden="true"></i>
                        {{#str}}coi_method_cite, gradereport_coifish{{/str}}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! Cognitive Presence methodology modal }}
    <div class="modal fade" id="gradetracker-coi-method-modal-cognitive" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa fa-info-circle me-1" aria-hidden="true"></i> {{#str}}coi_method_cognitive_title, gradereport_coifish{{/str}}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>{{#str}}coi_method_cognitive_desc, gradereport_coifish{{/str}}</p>
                    <h6 class="fw-bold mt-3">{{#str}}coi_method_signals_title, gradereport_coifish{{/str}}</h6>
                    <p>{{#str}}coi_method_cognitive_signals, gradereport_coifish{{/str}}</p>
                    <h6 class="fw-bold mt-3">{{#str}}coi_method_levels_title, gradereport_coifish{{/str}}</h6>
                    <p>{{#str}}coi_method_levels_desc, gradereport_coifish{{/str}}</p>
                    <div class="alert alert-secondary small py-2 mb-0">
                        <i class="fa fa-book me-1" aria-hidden="true"></i>
                        {{#str}}coi_method_cite, gradereport_coifish{{/str}}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! Teaching Presence methodology modal }}
    <div class="modal fade" id="gradetracker-coi-method-modal-teaching" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa fa-info-circle me-1" aria-hidden="true"></i> {{#str}}coi_method_teaching_title, gradereport_coifish{{/str}}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>{{#str}}coi_method_teaching_desc, gradereport_coifish{{/str}}</p>
                    <h6 class="fw-bold mt-3">{{#str}}coi_method_signals_title, gradereport_coifish{{/str}}</h6>
                    <p>{{#str}}coi_method_teaching_signals, gradereport_coifish{{/str}}</p>
                    <h6 class="fw-bold mt-3">{{#str}}coi_method_levels_title, gradereport_coifish{{/str}}</h6>
                    <p>{{#str}}coi_method_levels_desc, gradereport_coifish{{/str}}</p>
                    <div class="alert alert-secondary small py-2 mb-0">
                        <i class="fa fa-book me-1" aria-hidden="true"></i>
                        {{#str}}coi_method_cite, gradereport_coifish{{/str}}
                    </div>
                </div>
            </div>
        </div>
    </div>

{{/coi.haswidgets}}
