{{!
    @template gradereport_coifish/insights_view

    Teacher-only diagnostic and prescriptive insights for a student.

    Provides cross-referenced analysis of all widget data to surface
    actionable interventions. This addresses the gap identified in COI/LAK
    research: the absence of diagnostic and prescriptive analytics.

    The Community of Inquiry (COI) widgets are rendered at the top of this
    tab, above the risk summary. These widgets measure social, cognitive,
    and teaching presence — indicators targeted primarily at the teacher.

    Context variables required for this template:
    * coi.haswidgets (bool) - Whether any COI widgets are enabled and have data.
    * coi.widgets (array) - Array of COI widget objects (see progress_coi_widgets).
    * insights.hascards (bool) - Whether any diagnostic cards exist.
    * insights.nocards (bool) - Whether the student has no risk indicators.
    * insights.riskcount (int) - Number of flagged risk indicators.
    * insights.totalindicators (int) - Total indicators assessed.
    * insights.risklevel (string) - Overall risk: healthy, moderate, high.
    * insights.risklabel (string) - Human-readable risk label.
    * insights.cards (array) - Diagnostic insight cards.
      * icon (string) - Font Awesome icon name.
      * severity (string) - danger or warning.
      * title (string) - Card title.
      * diagnostic (string) - What is happening and why.
      * action (string) - Prescriptive intervention.
    * insights.stats (array) - Quick stat summary items.
      * label (string) - Stat label.
      * value (string) - Stat value.
      * isrisk (bool) - Whether this stat is flagged.

    Example context (json):
    {
        "insights": {
            "hascards": true,
            "nocards": false,
            "riskcount": 2,
            "totalindicators": 6,
            "risklevel": "moderate",
            "risklabel": "Moderate risk",
            "cards": [
                {
                    "icon": "line-chart",
                    "severity": "danger",
                    "title": "Declining performance",
                    "diagnostic": "Grades dropped over the last 3 assessments.",
                    "action": "Schedule a check-in to review recent feedback."
                }
            ],
            "stats": [
                {"label": "Marks achieved", "value": "65%", "isrisk": false}
            ],
            "hasstats": true
        }
    }
}}
{{! COI widgets — rendered at the top of the insights tab for teacher context }}
{{> gradereport_coifish/progress_coi_widgets }}

{{#insights}}
    <div class="gradetracker-insights mt-3">

        {{! Risk summary header }}
        <div class="gradetracker-insights-header gradetracker-risk-{{risklevel}} d-flex align-items-center p-3 mb-3">
            <div class="gradetracker-insights-risk-icon me-3">
                {{#nocards}}
                    <i class="fa fa-check-circle fa-2x" aria-hidden="true"></i>
                {{/nocards}}
                {{#hascards}}
                    <i class="fa fa-exclamation-circle fa-2x" aria-hidden="true"></i>
                {{/hascards}}
            </div>
            <div>
                <div class="gradetracker-insights-risk-label fw-bold">{{risklabel}}</div>
                <div class="gradetracker-insights-risk-detail text-muted">
                    {{riskcount}} / {{totalindicators}} {{#str}}insight_indicators_flagged, gradereport_coifish{{/str}}
                </div>
            </div>
        </div>

        {{! Quick stats row }}
        {{#hasstats}}
            <div class="gradetracker-insights-stats d-flex flex-wrap gap-2 mb-3">
                {{#stats}}
                    <div class="gradetracker-stat-chip {{#isrisk}}gradetracker-stat-risk{{/isrisk}}">
                        <span class="gradetracker-stat-label">{{label}}</span>
                        <span class="gradetracker-stat-value">{{value}}</span>
                    </div>
                {{/stats}}
            </div>
        {{/hasstats}}

        {{! No issues message }}
        {{#nocards}}
            <div class="alert alert-success d-flex align-items-center">
                <i class="fa fa-thumbs-up me-2" aria-hidden="true"></i>
                {{#str}}insight_no_issues, gradereport_coifish{{/str}}
            </div>
        {{/nocards}}

        {{! Diagnostic cards }}
        {{#hascards}}
            <div class="gradetracker-insights-cards">
                {{#cards}}
                    <div class="gradetracker-insight-card gradetracker-insight-{{severity}} mb-3">
                        <div class="gradetracker-insight-card-header">
                            <i class="fa fa-{{icon}} me-2" aria-hidden="true"></i>
                            {{title}}
                        </div>
                        <div class="gradetracker-insight-card-body">
                            <div class="gradetracker-insight-diagnostic">
                                <span class="gradetracker-insight-label">{{#str}}insight_label_diagnostic, gradereport_coifish{{/str}}</span>
                                {{diagnostic}}
                            </div>
                            <div class="gradetracker-insight-action">
                                <span class="gradetracker-insight-label">{{#str}}insight_label_action, gradereport_coifish{{/str}}</span>
                                {{action}}
                            </div>
                        </div>
                        <div class="gradetracker-insight-card-footer d-flex justify-content-between align-items-center">
                            <a href="#" class="gradetracker-detail-link" data-bs-toggle="modal" data-bs-target="#gradetracker-detail-{{cardid}}">
                                <i class="fa fa-info-circle me-1" aria-hidden="true"></i>{{#str}}detail_link, gradereport_coifish{{/str}}
                            </a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary gradetracker-log-intervention-btn"
                                    data-diagnostictype="{{diagnostictype}}"
                                    data-scope="individual"
                                    data-cardtitle="{{title}}"
                                    data-students="[{&quot;id&quot;:{{studentid}},&quot;name&quot;:&quot;{{studentname}}&quot;}]">
                                <i class="fa fa-clipboard me-1" aria-hidden="true"></i>{{#str}}intervention_log_btn, gradereport_coifish{{/str}}
                            </button>
                        </div>
                    </div>

                    {{! Detail modal }}
                    <div class="modal fade" id="gradetracker-detail-{{cardid}}" tabindex="-1" aria-labelledby="gradetracker-detail-{{cardid}}-label" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-scrollable">
                            <div class="modal-content">
                                <div class="modal-header gradetracker-detail-header gradetracker-detail-header-{{severity}}">
                                    <h5 class="modal-title" id="gradetracker-detail-{{cardid}}-label">
                                        <i class="fa fa-{{icon}} me-2" aria-hidden="true"></i>{{title}}
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    {{#hasmetrics}}
                                    <div class="gradetracker-detail-section mb-4">
                                        <h6 class="gradetracker-detail-section-title">
                                            <i class="fa fa-tachometer me-1" aria-hidden="true"></i>
                                            {{#str}}detail_heading_metrics, gradereport_coifish{{/str}}
                                        </h6>
                                        <div class="gradetracker-detail-metrics d-flex flex-wrap gap-2">
                                            {{#metrics}}
                                                <div class="gradetracker-detail-metric-chip">
                                                    <span class="gradetracker-detail-metric-label">{{label}}</span>
                                                    <span class="gradetracker-detail-metric-value">{{value}}</span>
                                                </div>
                                            {{/metrics}}
                                        </div>
                                    </div>
                                    {{/hasmetrics}}
                                    <div class="gradetracker-detail-section mb-4">
                                        <h6 class="gradetracker-detail-section-title">
                                            <i class="fa fa-cogs me-1" aria-hidden="true"></i>
                                            {{#str}}detail_heading_methodology, gradereport_coifish{{/str}}
                                        </h6>
                                        <p class="gradetracker-detail-text">{{methodology}}</p>
                                    </div>
                                    {{#hasthresholds}}
                                    <div class="gradetracker-detail-section mb-4">
                                        <h6 class="gradetracker-detail-section-title">
                                            <i class="fa fa-sliders me-1" aria-hidden="true"></i>
                                            {{#str}}detail_heading_thresholds, gradereport_coifish{{/str}}
                                        </h6>
                                        <table class="table table-sm table-borderless gradetracker-detail-threshold-table">
                                            <tbody>
                                                {{#thresholds}}
                                                    <tr>
                                                        <td class="gradetracker-detail-threshold-label">{{label}}</td>
                                                        <td>{{value}}</td>
                                                    </tr>
                                                {{/thresholds}}
                                            </tbody>
                                        </table>
                                    </div>
                                    {{/hasthresholds}}
                                    {{#haslogdata}}
                                    <div class="gradetracker-detail-section mb-4">
                                        <h6 class="gradetracker-detail-section-title">
                                            <i class="fa fa-list-alt me-1" aria-hidden="true"></i>
                                            {{#str}}detail_heading_logdata, gradereport_coifish{{/str}}
                                        </h6>
                                        <div class="gradetracker-logdata-table-wrap">
                                            <table class="table table-sm table-bordered gradetracker-logdata-table">
                                                <thead class="table-light">
                                                    <tr>
                                                        {{#logcolumns}}
                                                            <th>{{.}}</th>
                                                        {{/logcolumns}}
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    {{#logdata}}
                                                        <tr class="{{#highlight}}gradetracker-logdata-highlight{{/highlight}}">
                                                            {{#cells}}
                                                                <td>{{{.}}}</td>
                                                            {{/cells}}
                                                        </tr>
                                                    {{/logdata}}
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    {{/haslogdata}}
                                    <div class="gradetracker-detail-section mb-4">
                                        <h6 class="gradetracker-detail-section-title">
                                            <i class="fa fa-lightbulb-o me-1" aria-hidden="true"></i>
                                            {{#str}}detail_heading_rationale, gradereport_coifish{{/str}}
                                        </h6>
                                        <p class="gradetracker-detail-text">{{rationale}}</p>
                                    </div>
                                    {{#hasstudents}}
                                    <div class="gradetracker-detail-section">
                                        <h6 class="gradetracker-detail-section-title">
                                            <i class="fa fa-user me-1" aria-hidden="true"></i>
                                            {{#str}}detail_heading_students, gradereport_coifish{{/str}}
                                        </h6>
                                        <table class="table table-sm table-bordered table-hover gradetracker-detail-student-table">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>{{#str}}student, gradereport_coifish{{/str}}</th>
                                                    <th>{{#str}}detail_heading_datapoint, gradereport_coifish{{/str}}</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {{#students}}
                                                    <tr>
                                                        <td><a href="{{viewurl}}">{{fullname}} <i class="fa fa-external-link fa-fw small text-muted" aria-hidden="true"></i></a></td>
                                                        <td class="text-muted">{{metric}}</td>
                                                    </tr>
                                                {{/students}}
                                            </tbody>
                                        </table>
                                    </div>
                                    {{/hasstudents}}
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">{{#str}}detail_close, gradereport_coifish{{/str}}</button>
                                </div>
                            </div>
                        </div>
                    </div>
                {{/cards}}
            </div>
        {{/hascards}}

        {{! Intervention history }}
        {{#interventionhistory}}
            {{> gradereport_coifish/intervention_history}}
        {{/interventionhistory}}

    </div>

    {{! Intervention logging modal }}
    {{> gradereport_coifish/intervention_modal}}

    {{#js}}
        require(['gradereport_coifish/intervention'], function(mod) {
            mod.init();
        });
    {{/js}}
{{/insights}}
