{{!
    @template gradereport_coifish/action_bar

    Template for the teacher action bar with group and user selectors.

    Context variables required for this template:
    * actionurl (string) - Form action URL.
    * courseid (int) - The course ID.
    * hasgroups (bool) - Whether groups are available.
    * groups (array) - Array of group objects with groupid, groupname, selected.
    * users (array) - Array of user objects with userid, fullname, selected.

    Example context (json):
    {
        "actionurl": "/grade/report/gradetracker/index.php",
        "courseid": 2,
        "hasgroups": true,
        "groups": [
            {"groupid": 0, "groupname": "All participants", "selected": true}
        ],
        "users": [
            {"userid": 0, "fullname": "All participants", "selected": true}
        ]
    }
}}
{{#showcoordinatortab}}
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link {{^iscoordinatorview}}active{{/iscoordinatorview}}" href="{{studentsurl}}">
                <i class="fa fa-users me-1" aria-hidden="true"></i>
                {{#str}}students_tab, gradereport_coifish{{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#iscoordinatorview}}active{{/iscoordinatorview}}" href="{{coordinatorurl}}"
               title="{{#str}}coordinator_tab_title, gradereport_coifish{{/str}}">
                <i class="fa fa-briefcase me-1" aria-hidden="true"></i>
                {{#str}}coordinator_tab, gradereport_coifish{{/str}}
            </a>
        </li>
    </ul>
{{/showcoordinatortab}}
{{#showstudentcontrols}}
<div class="gradereport-coifish-actionbar mb-3">
    <form method="get" action="{{actionurl}}" class="d-flex align-items-center flex-wrap gap-2">
        <input type="hidden" name="id" value="{{courseid}}">
        <input type="hidden" name="view" id="gradetracker-view-param" value="{{activeview}}">

        {{#hasgroups}}
            <div class="d-flex align-items-center">
                <label for="gradetracker-group" class="me-2 mb-0 text-nowrap">
                    {{#str}}group, core{{/str}}:
                </label>
                <select id="gradetracker-group" name="group" class="form-select form-select-sm"
                        onchange="this.form.elements['userid'].value='0'; this.form.submit();">
                    {{#groups}}
                        <option value="{{groupid}}" {{#selected}}selected{{/selected}}>
                            {{groupname}}
                        </option>
                    {{/groups}}
                </select>
            </div>
        {{/hasgroups}}

        <div class="d-flex align-items-center">
            <label for="gradetracker-user" class="me-2 mb-0 text-nowrap">
                {{#str}}student, gradereport_coifish{{/str}}:
            </label>
            <select id="gradetracker-user" name="userid" class="form-select form-select-sm"
                    onchange="this.form.submit();">
                {{#users}}
                    <option value="{{userid}}" {{#selected}}selected{{/selected}}>
                        {{fullname}}
                    </option>
                {{/users}}
            </select>
        </div>

        <div class="d-flex align-items-center gap-3 ms-auto">
            {{#showwidgetstoggle}}
                <div class="form-check form-switch mb-0">
                    <input type="checkbox"
                           class="form-check-input"
                           role="switch"
                           id="gradetracker-widgets-toggle"
                           {{#widgetsenabled}}checked{{/widgetsenabled}}
                           onchange="window.location.href = '{{togglewidgetsurl}}';">
                    <label class="form-check-label small" for="gradetracker-widgets-toggle">
                        {{#widgetsenabled}}
                            <i class="fa fa-eye me-1" aria-hidden="true"></i>
                        {{/widgetsenabled}}
                        {{^widgetsenabled}}
                            <i class="fa fa-eye-slash me-1" aria-hidden="true"></i>
                        {{/widgetsenabled}}
                        {{#str}}display_widgets, gradereport_coifish{{/str}}
                    </label>
                </div>
            {{/showwidgetstoggle}}
            <a href="{{settingsurl}}" class="btn btn-sm btn-outline-secondary">
                <i class="fa fa-cog me-1" aria-hidden="true"></i>
                {{#str}}coursesettings, gradereport_coifish{{/str}}
            </a>
        </div>
    </form>
</div>
{{/showstudentcontrols}}
