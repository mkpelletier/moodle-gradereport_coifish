{{!
    @template gradereport_coifish/cohort_insights_view

    Teacher-only cohort-level diagnostic and prescriptive analytics.

    Aggregates Community of Inquiry presence indicators, grade distribution,
    and risk diagnostics across the selected group or all participants.

    Context variables required for this template:
    * cohortinsights.hasdata (bool) - Whether data exists.
    * cohortinsights.usercount (int) - Number of students.
    * cohortinsights.presence (object) - COI presence breakdowns.
      * social (object) - Social Presence levels.
      * cognitive (object) - Cognitive Presence levels.
      * teaching (object) - Teaching Presence levels.
        Each presence object has:
        * title (string) - Presence type title.
        * bars (array) - Level distribution bars.
          * level (string) - Level class (none, emerging, etc).
          * label (string) - Human-readable level label.
          * count (int) - Number of students at this level.
          * height (int) - Bar height percentage (0-100).
          * hascount (bool) - Whether count > 0.
          * percentage (int) - Percentage of cohort.
        * healthypct (int) - Percentage at developing or above.
        * ishealthy (bool) - Whether healthypct >= 60.
        * isconcern (bool) - Whether healthypct < 40.
    * cohortinsights.distribution (array) - Grade distribution buckets.
      * label (string) - Bucket label.
      * count (int) - Student count.
      * height (int) - Bar height percentage.
      * hascount (bool) - Whether count > 0.
    * cohortinsights.classaverage (float|null) - Class average percentage.
    * cohortinsights.cards (array) - Diagnostic insight cards.
    * cohortinsights.hascards (bool) - Whether diagnostic cards exist.
    * cohortinsights.nocards (bool) - No risk indicators.
    * cohortinsights.atrisk (array) - At-risk students.
    * cohortinsights.hasatrisk (bool) - Whether at-risk students exist.
    * cohortinsights.stale (array) - Stale/inactive students.
    * cohortinsights.hasstale (bool) - Whether stale students exist.
    * cohortinsights.stats (array) - Quick stat summary chips.
    * cohortinsights.risklevel (string) - Overall: healthy, moderate, high.
    * cohortinsights.risklabel (string) - Human-readable risk label.

    Example context (json):
    {
        "cohortinsights": {
            "hasdata": true,
            "usercount": 25,
            "risklevel": "moderate",
            "risklabel": "Some concerns",
            "hascards": true,
            "nocards": false,
            "riskcount": 2,
            "stats": [{"label": "Students", "value": "25", "isrisk": false}],
            "hasstats": true,
            "presence": {
                "social": {
                    "title": "Social Presence",
                    "bars": [{"level": "none", "label": "Not started", "count": 5, "height": 100, "hascount": true, "percentage": 20}],
                    "healthypct": 60,
                    "ishealthy": true,
                    "isconcern": false
                }
            },
            "distribution": [{"label": "0-49%", "count": 3, "height": 60, "hascount": true}],
            "classaverage": 65.2,
            "cards": [{"icon": "users", "severity": "warning", "title": "Low social presence", "diagnostic": "30% of students...", "action": "Consider..."}],
            "atrisk": [{"userid": 5, "fullname": "John Smith", "riskflags": 3, "percentage": "42%", "viewurl": "/grade/report/coifish/index.php?id=2&userid=5"}],
            "hasatrisk": true,
            "stale": [],
            "hasstale": false
        }
    }
}}
{{#cohortinsights}}
{{#hasdata}}
    <div class="gradetracker-cohort-insights mt-3">

        {{! Risk summary header }}
        <div class="gradetracker-insights-header gradetracker-risk-{{risklevel}} d-flex align-items-center p-3 mb-3">
            <div class="gradetracker-insights-risk-icon me-3">
                {{#nocards}}
                    <i class="fa fa-check-circle fa-2x" aria-hidden="true"></i>
                {{/nocards}}
                {{#hascards}}
                    <i class="fa fa-exclamation-circle fa-2x" aria-hidden="true"></i>
                {{/hascards}}
            </div>
            <div>
                <div class="gradetracker-insights-risk-label fw-bold">{{risklabel}}</div>
                <div class="gradetracker-insights-risk-detail text-muted">
                    {{riskcount}} {{#str}}cohort_diagnostics_flagged, gradereport_coifish{{/str}}
                    &middot; {{usercount}} {{#str}}cohort_stat_students, gradereport_coifish{{/str}}
                </div>
            </div>
        </div>

        {{! Quick stats row }}
        {{#hasstats}}
            <div class="gradetracker-insights-stats d-flex flex-wrap gap-2 mb-3">
                {{#stats}}
                    <div class="gradetracker-stat-chip {{#isrisk}}gradetracker-stat-risk{{/isrisk}}">
                        <span class="gradetracker-stat-label">{{label}}</span>
                        <span class="gradetracker-stat-value">{{value}}</span>
                    </div>
                {{/stats}}
            </div>
        {{/hasstats}}

        {{! COI Presence breakdown }}
        <div class="gradetracker-cohort-presence mb-4">
            <h5 class="gradetracker-cohort-section-title mb-3">
                <i class="fa fa-pie-chart me-1" aria-hidden="true"></i>
                {{#str}}cohort_presence_title, gradereport_coifish{{/str}}
            </h5>
            <div class="d-flex flex-wrap gap-3">
                {{#presence.social}}
                    {{> gradereport_coifish/cohort_presence_card }}
                {{/presence.social}}
                {{#presence.cognitive}}
                    {{> gradereport_coifish/cohort_presence_card }}
                {{/presence.cognitive}}
                {{#presence.teaching}}
                    {{> gradereport_coifish/cohort_presence_card }}
                {{/presence.teaching}}
            </div>
        </div>

        {{! Grade distribution }}
        <div class="gradetracker-cohort-distribution mb-4">
            <h5 class="gradetracker-cohort-section-title mb-3">
                <i class="fa fa-bar-chart me-1" aria-hidden="true"></i>
                {{#str}}cohort_distribution_title, gradereport_coifish{{/str}}
                {{#classaverage}}
                    <span class="text-muted fw-normal ms-2" style="font-size:0.85em;">
                        {{#str}}cohort_stat_average, gradereport_coifish{{/str}}: {{classaverage}}%
                        {{#classmedian}}
                            &middot; {{#str}}cohort_stat_median, gradereport_coifish{{/str}}: {{classmedian}}%
                        {{/classmedian}}
                    </span>
                {{/classaverage}}
            </h5>
            <div class="gradetracker-distribution-chart d-flex align-items-end gap-1">
                {{#distribution}}
                    <div class="gradetracker-distribution-bar-group text-center">
                        {{#hascount}}
                            <div class="gradetracker-distribution-count small text-muted">{{count}}</div>
                        {{/hascount}}
                        <div class="gradetracker-distribution-bar" style="height: {{height}}%;"
                             data-bs-toggle="tooltip" title="{{label}}: {{count}}"></div>
                        <div class="gradetracker-distribution-label small text-muted mt-1">{{label}}</div>
                    </div>
                {{/distribution}}
            </div>
        </div>

        {{! S3 Risk Quadrant Scatter Graph }}
        {{#showscatter}}
            <div class="gradetracker-cohort-riskquadrant mb-4">
                <h5 class="gradetracker-cohort-section-title mb-3">
                    <i class="fa fa-dot-circle-o me-1" aria-hidden="true"></i>
                    {{#str}}riskquadrant_title, gradereport_coifish{{/str}}
                </h5>
                <p class="text-muted small mb-2">
                    {{#str}}riskquadrant_desc, gradereport_coifish{{/str}}
                </p>
                <div id="gradetracker-riskquadrant"
                     class="gradetracker-riskquadrant-container"
                     data-scatter="{{scatterjson}}"
                     data-engagement-threshold="{{engagementthreshold}}"
                     data-grade-threshold="{{gradethreshold}}"
                     data-label-x="{{#str}}riskquadrant_axis_engagement, gradereport_coifish{{/str}}"
                     data-label-y="{{#str}}riskquadrant_axis_grade, gradereport_coifish{{/str}}"
                     data-label-tr="{{#str}}riskquadrant_ontrack, gradereport_coifish{{/str}}"
                     data-label-tl="{{#str}}riskquadrant_underengaged, gradereport_coifish{{/str}}"
                     data-label-br="{{#str}}riskquadrant_academicrisk, gradereport_coifish{{/str}}"
                     data-label-bl="{{#str}}riskquadrant_atrisk, gradereport_coifish{{/str}}">
                </div>
            </div>
        {{/showscatter}}

        {{! Forum Interaction Sociogram }}
        {{#showsociogram}}
            <div class="gradetracker-cohort-sociogram mb-4">
                <h5 class="gradetracker-cohort-section-title mb-3">
                    <i class="fa fa-share-alt me-1" aria-hidden="true"></i>
                    {{#str}}sociogram_title, gradereport_coifish{{/str}}
                </h5>
                <p class="text-muted small mb-2">
                    {{#str}}sociogram_desc, gradereport_coifish{{/str}}
                </p>
                <div class="gradetracker-sociogram-legend d-flex flex-wrap gap-3 mb-2 small text-muted">
                    <span><span class="gradetracker-sociogram-legend-dot gradetracker-sociogram-dot-green"></span> {{#str}}sociogram_legend_passing, gradereport_coifish{{/str}}</span>
                    <span><span class="gradetracker-sociogram-legend-dot gradetracker-sociogram-dot-amber"></span> {{#str}}sociogram_legend_borderline, gradereport_coifish{{/str}}</span>
                    <span><span class="gradetracker-sociogram-legend-dot gradetracker-sociogram-dot-red"></span> {{#str}}sociogram_legend_failing, gradereport_coifish{{/str}}</span>
                    <span><span class="gradetracker-sociogram-legend-dot gradetracker-sociogram-dot-grey"></span> {{#str}}sociogram_legend_ungraded, gradereport_coifish{{/str}}</span>
                </div>
                <div id="gradetracker-sociogram"
                     class="gradetracker-sociogram-container"
                     data-nodes="{{sociogramnodesjson}}"
                     data-edges="{{sociogramedgesjson}}"
                     data-pass-threshold="{{gradethreshold}}">
                </div>
            </div>
        {{/showsociogram}}

        {{! No issues message }}
        {{#nocards}}
            <div class="alert alert-success d-flex align-items-center">
                <i class="fa fa-thumbs-up me-2" aria-hidden="true"></i>
                {{#str}}cohort_no_issues, gradereport_coifish{{/str}}
            </div>
        {{/nocards}}

        {{! Diagnostic cards }}
        {{#hascards}}
            <div class="gradetracker-cohort-diagnostics mb-4">
                <h5 class="gradetracker-cohort-section-title mb-3">
                    <i class="fa fa-stethoscope me-1" aria-hidden="true"></i>
                    {{#str}}cohort_diagnostics_title, gradereport_coifish{{/str}}
                </h5>
                <div class="gradetracker-insights-cards">
                    {{#cards}}
                        <div class="gradetracker-insight-card gradetracker-insight-{{severity}} mb-3">
                            <div class="gradetracker-insight-card-header">
                                <i class="fa fa-{{icon}} me-2" aria-hidden="true"></i>
                                {{title}}
                            </div>
                            <div class="gradetracker-insight-card-body">
                                <div class="gradetracker-insight-diagnostic">
                                    <span class="gradetracker-insight-label">{{#str}}insight_label_diagnostic, gradereport_coifish{{/str}}</span>
                                    {{diagnostic}}
                                </div>
                                <div class="gradetracker-insight-action">
                                    <span class="gradetracker-insight-label">{{#str}}insight_label_action, gradereport_coifish{{/str}}</span>
                                    {{action}}
                                </div>
                            </div>
                            <div class="gradetracker-insight-card-footer">
                                <a href="#" class="gradetracker-detail-link" data-bs-toggle="modal" data-bs-target="#gradetracker-detail-{{cardid}}">
                                    <i class="fa fa-info-circle me-1" aria-hidden="true"></i>{{#str}}detail_link, gradereport_coifish{{/str}}
                                </a>
                            </div>
                        </div>

                        {{! Detail modal }}
                        <div class="modal fade" id="gradetracker-detail-{{cardid}}" tabindex="-1" aria-labelledby="gradetracker-detail-{{cardid}}-label" aria-hidden="true">
                            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                                <div class="modal-content">
                                    <div class="modal-header gradetracker-detail-header gradetracker-detail-header-{{severity}}">
                                        <h5 class="modal-title" id="gradetracker-detail-{{cardid}}-label">
                                            <i class="fa fa-{{icon}} me-2" aria-hidden="true"></i>{{title}}
                                        </h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">

                                        {{! Key metrics }}
                                        {{#hasmetrics}}
                                        <div class="gradetracker-detail-section mb-4">
                                            <h6 class="gradetracker-detail-section-title">
                                                <i class="fa fa-tachometer me-1" aria-hidden="true"></i>
                                                {{#str}}detail_heading_metrics, gradereport_coifish{{/str}}
                                            </h6>
                                            <div class="gradetracker-detail-metrics d-flex flex-wrap gap-2">
                                                {{#metrics}}
                                                    <div class="gradetracker-detail-metric-chip">
                                                        <span class="gradetracker-detail-metric-label">{{label}}</span>
                                                        <span class="gradetracker-detail-metric-value">{{value}}</span>
                                                    </div>
                                                {{/metrics}}
                                            </div>
                                        </div>
                                        {{/hasmetrics}}

                                        {{! How we calculated this }}
                                        <div class="gradetracker-detail-section mb-4">
                                            <h6 class="gradetracker-detail-section-title">
                                                <i class="fa fa-cogs me-1" aria-hidden="true"></i>
                                                {{#str}}detail_heading_methodology, gradereport_coifish{{/str}}
                                            </h6>
                                            <p class="gradetracker-detail-text">{{methodology}}</p>
                                        </div>

                                        {{! Applied thresholds }}
                                        {{#hasthresholds}}
                                        <div class="gradetracker-detail-section mb-4">
                                            <h6 class="gradetracker-detail-section-title">
                                                <i class="fa fa-sliders me-1" aria-hidden="true"></i>
                                                {{#str}}detail_heading_thresholds, gradereport_coifish{{/str}}
                                            </h6>
                                            <table class="table table-sm table-borderless gradetracker-detail-threshold-table">
                                                <tbody>
                                                    {{#thresholds}}
                                                        <tr>
                                                            <td class="gradetracker-detail-threshold-label">{{label}}</td>
                                                            <td>{{value}}</td>
                                                        </tr>
                                                    {{/thresholds}}
                                                </tbody>
                                            </table>
                                        </div>
                                        {{/hasthresholds}}

                                        {{! Why this matters }}
                                        <div class="gradetracker-detail-section mb-4">
                                            <h6 class="gradetracker-detail-section-title">
                                                <i class="fa fa-lightbulb-o me-1" aria-hidden="true"></i>
                                                {{#str}}detail_heading_rationale, gradereport_coifish{{/str}}
                                            </h6>
                                            <p class="gradetracker-detail-text">{{rationale}}</p>
                                        </div>

                                        {{! Affected students }}
                                        {{#hasstudents}}
                                        <div class="gradetracker-detail-section">
                                            <h6 class="gradetracker-detail-section-title">
                                                <i class="fa fa-user me-1" aria-hidden="true"></i>
                                                {{#str}}detail_heading_students, gradereport_coifish{{/str}}
                                            </h6>
                                            <table class="table table-sm table-bordered table-hover gradetracker-detail-student-table">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>{{#str}}student, gradereport_coifish{{/str}}</th>
                                                        <th>{{#str}}detail_heading_datapoint, gradereport_coifish{{/str}}</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    {{#students}}
                                                        <tr>
                                                            <td>
                                                                <a href="{{viewurl}}">{{fullname}} <i class="fa fa-external-link fa-fw small text-muted" aria-hidden="true"></i></a>
                                                            </td>
                                                            <td class="text-muted">{{metric}}</td>
                                                        </tr>
                                                    {{/students}}
                                                </tbody>
                                            </table>
                                        </div>
                                        {{/hasstudents}}

                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">{{#str}}detail_close, gradereport_coifish{{/str}}</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {{/cards}}
                </div>
            </div>
        {{/hascards}}

        {{! Course design notice — shown when COI flags may reflect limited social opportunities }}
        {{#hascoursedesign}}
            {{#coursedesign}}
                <div class="gradetracker-coursedesign-notice mb-4">
                    <div class="gradetracker-insight-card gradetracker-insight-{{severity}} mb-0">
                        <div class="gradetracker-insight-card-header">
                            <i class="fa fa-{{icon}} me-2" aria-hidden="true"></i>
                            {{title}}
                        </div>
                        <div class="gradetracker-insight-card-body">
                            <div class="gradetracker-insight-diagnostic">
                                <span class="gradetracker-insight-label">{{#str}}coursedesign_curriculum_label, gradereport_coifish{{/str}}</span>
                                {{diagnostic}}
                            </div>
                            <div class="gradetracker-insight-action">
                                <span class="gradetracker-insight-label">{{#str}}insight_label_action, gradereport_coifish{{/str}}</span>
                                {{action}}
                            </div>
                        </div>
                    </div>
                </div>
            {{/coursedesign}}
        {{/hascoursedesign}}

        {{! At-risk students list }}
        {{#hasatrisk}}
            <div class="gradetracker-cohort-atrisk mb-4">
                <h5 class="gradetracker-cohort-section-title mb-3">
                    <i class="fa fa-exclamation-triangle me-1" aria-hidden="true"></i>
                    {{#str}}cohort_atrisk_title, gradereport_coifish{{/str}}
                </h5>
                <p class="text-muted small mb-2">
                    {{#str}}cohort_atrisk_desc, gradereport_coifish{{/str}}
                </p>
                <table class="table table-sm table-bordered table-hover gradetracker-atrisk-table">
                    <thead class="table-light">
                        <tr>
                            <th>{{#str}}student, gradereport_coifish{{/str}}</th>
                            <th>{{#str}}coursetotal, gradereport_coifish{{/str}}</th>
                            <th>{{#str}}cohort_sp_title, gradereport_coifish{{/str}}</th>
                            <th>{{#str}}cohort_cp_title, gradereport_coifish{{/str}}</th>
                            <th>{{#str}}cohort_tp_title, gradereport_coifish{{/str}}</th>
                            <th>{{#str}}cohort_atrisk_concerns, gradereport_coifish{{/str}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#atrisk}}
                            <tr>
                                <td>
                                    <a href="{{viewurl}}" data-bs-toggle="tooltip" title="{{#str}}cohort_atrisk_drilldown, gradereport_coifish{{/str}}">
                                        {{fullname}}
                                        <i class="fa fa-external-link fa-fw small text-muted" aria-hidden="true"></i>
                                    </a>
                                </td>
                                <td>{{percentage}}</td>
                                <td><span class="badge gradetracker-coi-level-badge gradetracker-coi-level-{{spclass}}">{{splevel}}</span></td>
                                <td><span class="badge gradetracker-coi-level-badge gradetracker-coi-level-{{cpclass}}">{{cplevel}}</span></td>
                                <td><span class="badge gradetracker-coi-level-badge gradetracker-coi-level-{{tpclass}}">{{tplevel}}</span></td>
                                <td class="small text-muted">{{flaglist}}</td>
                            </tr>
                        {{/atrisk}}
                    </tbody>
                </table>
            </div>
        {{/hasatrisk}}

        {{! Stale / inactive students }}
        {{#hasstale}}
            <div class="gradetracker-cohort-stale mb-4">
                <h5 class="gradetracker-cohort-section-title mb-3">
                    <i class="fa fa-clock-o me-1" aria-hidden="true"></i>
                    {{#str}}cohort_stale_title, gradereport_coifish{{/str}}
                </h5>
                <div class="d-flex flex-wrap gap-2">
                    {{#stale}}
                        <a href="{{viewurl}}" class="gradetracker-stale-chip badge bg-warning text-dark text-decoration-none">
                            {{fullname}} <span class="text-muted">({{days}}d)</span>
                        </a>
                    {{/stale}}
                </div>
            </div>
        {{/hasstale}}

        {{! Cross-group comparison }}
        {{#crossgroup}}
        {{#hasgroups}}
            <div class="gradetracker-cohort-crossgroup mb-4">
                <h5 class="gradetracker-cohort-section-title mb-3">
                    <i class="fa fa-users me-1" aria-hidden="true"></i>
                    {{#str}}cohort_crossgroup_title, gradereport_coifish{{/str}}
                </h5>
                <p class="text-muted small mb-2">
                    {{#str}}cohort_crossgroup_desc, gradereport_coifish{{/str}}
                </p>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered table-hover gradetracker-crossgroup-table">
                        <thead class="table-light">
                            <tr>
                                <th>{{#str}}cohort_crossgroup_group, gradereport_coifish{{/str}}</th>
                                <th class="text-center">{{#str}}cohort_stat_students, gradereport_coifish{{/str}}</th>
                                <th class="text-center">{{#str}}cohort_stat_average, gradereport_coifish{{/str}}</th>
                                <th class="text-center">{{#str}}cohort_stat_belowpass, gradereport_coifish{{/str}}</th>
                                <th class="text-center">{{#str}}cohort_crossgroup_sphealth, gradereport_coifish{{/str}}</th>
                                <th class="text-center">{{#str}}cohort_stat_atrisk, gradereport_coifish{{/str}}</th>
                                <th class="text-center border-start" title="{{#str}}crossgroup_col_forum_title, gradereport_coifish{{/str}}">
                                    <i class="fa fa-comments text-muted" aria-hidden="true"></i>
                                </th>
                                <th class="text-center" title="{{#str}}crossgroup_col_messages_title, gradereport_coifish{{/str}}">
                                    <i class="fa fa-envelope text-muted" aria-hidden="true"></i>
                                </th>
                                <th class="text-center" title="{{#str}}crossgroup_col_turnaround_title, gradereport_coifish{{/str}}">
                                    <i class="fa fa-clock-o text-muted" aria-hidden="true"></i>
                                </th>
                                <th class="text-center" title="{{#str}}crossgroup_col_fbcoverage_title, gradereport_coifish{{/str}}">
                                    <i class="fa fa-comment-o text-muted" aria-hidden="true"></i>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#groups}}
                                <tr class="{{#iscurrent}}table-active{{/iscurrent}}">
                                    <td>
                                        <a href="{{viewurl}}">
                                            {{groupname}}
                                            {{#iscurrent}}
                                                <span class="badge bg-secondary ms-1">{{#str}}cohort_crossgroup_current, gradereport_coifish{{/str}}</span>
                                            {{/iscurrent}}
                                        </a>
                                    </td>
                                    <td class="text-center">{{studentcount}}</td>
                                    <td class="text-center">{{average}}</td>
                                    <td class="text-center {{#belowpass}}text-danger fw-bold{{/belowpass}}">{{belowpass}}</td>
                                    <td class="text-center">
                                        {{#sphealthy}}<span class="text-success">{{sphealthpct}}%</span>{{/sphealthy}}
                                        {{#spconcern}}<span class="text-danger fw-bold">{{sphealthpct}}%</span>{{/spconcern}}
                                        {{^sphealthy}}{{^spconcern}}<span class="text-muted">{{sphealthpct}}%</span>{{/spconcern}}{{/sphealthy}}
                                    </td>
                                    <td class="text-center {{#hasatrisk}}text-danger fw-bold{{/hasatrisk}}">{{atriskcount}}</td>
                                    <td class="text-center border-start">{{teacherforumposts}}</td>
                                    <td class="text-center">{{teachermessages}}</td>
                                    <td class="text-center">
                                        {{#teacherturnaround}}{{teacherturnaround}}d{{/teacherturnaround}}
                                        {{^teacherturnaround}}<span class="text-muted">-</span>{{/teacherturnaround}}
                                    </td>
                                    <td class="text-center">
                                        {{#teacherfbcoverage}}{{teacherfbcoverage}}%{{/teacherfbcoverage}}
                                        {{^teacherfbcoverage}}<span class="text-muted">-</span>{{/teacherfbcoverage}}
                                    </td>
                                </tr>
                            {{/groups}}
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td class="fw-bold">
                                    {{#str}}cohort_crossgroup_allgroups, gradereport_coifish{{/str}}
                                    <span class="text-muted fw-normal">({{groupcount}} {{#str}}cohort_crossgroup_groups, gradereport_coifish{{/str}})</span>
                                </td>
                                <td class="text-center" colspan="1"></td>
                                <td class="text-center fw-bold">{{courseaverage}}</td>
                                <td class="text-center" colspan="7"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                {{! Cross-group diagnostic cards }}
                {{#hasdiagnostics}}
                    <div class="gradetracker-cohort-crossgroup-diagnostics mt-3">
                        <h6 class="gradetracker-cohort-subsection-title mb-2">
                            <i class="fa fa-search me-1" aria-hidden="true"></i>
                            {{#str}}crossgroup_diag_heading, gradereport_coifish{{/str}}
                        </h6>
                        {{#diagnostics}}
                            <div class="gradetracker-insight-card gradetracker-insight-{{severity}} mb-3">
                                <div class="gradetracker-insight-card-header">
                                    <i class="fa fa-{{icon}} me-2" aria-hidden="true"></i>
                                    {{title}}
                                </div>
                                <div class="gradetracker-insight-card-body">
                                    <div class="gradetracker-insight-diagnostic">
                                        <span class="gradetracker-insight-label">{{#str}}insight_label_diagnostic, gradereport_coifish{{/str}}</span>
                                        {{diagnostic}}
                                    </div>
                                    <div class="gradetracker-insight-action">
                                        <span class="gradetracker-insight-label">{{#str}}insight_label_action, gradereport_coifish{{/str}}</span>
                                        {{action}}
                                    </div>
                                </div>
                            </div>
                        {{/diagnostics}}
                    </div>
                {{/hasdiagnostics}}
            </div>
        {{/hasgroups}}
        {{/crossgroup}}

    </div>
{{/hasdata}}
{{/cohortinsights}}
